# Copy this file to .env.local and fill in real values.
# .env.local is ignored by git and is for local development only.
# For deployed environments, set these in Vercel Project Settings -> Environment Variables.

# -----------------------------
# AI Provider (Groq)
# -----------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Base system prompt used by /api/reflect and as fallback by /api/chat
TRG_SYSTEM_PROMPT=

# Optional chat-specific override prompt. If omitted, chat uses TRG_SYSTEM_PROMPT.
TRG_CHAT_SYSTEM_PROMPT=

# -----------------------------
# Premium Auth (JWT)
# -----------------------------
JWT_SECRET=replace_with_a_long_random_secret

# -----------------------------
# Paystack
# -----------------------------
PAYSTACK_PUBLIC_KEY=pk_test_or_live_key
PAYSTACK_SECRET_KEY=sk_test_or_live_key

# Pricing config used by API verification/config endpoints.
# Set to 2000 for 20 GHS pricing.
PAYWALL_AMOUNT_KOBO=2000
PAYWALL_CURRENCY=GHS

# -----------------------------
# Local run modes
# -----------------------------
# Static-only preview (no /api endpoints):
#   npx serve .
# Full app with serverless APIs:
#   npm run local
